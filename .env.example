# Copy to .env and fill in. .env is gitignored.

# Google Cloud OAuth client id (type: Chrome extension). Required for sign-in.
WXT_OAUTH_CLIENT_ID=

# Manifest public key (manifest.key). Required — pins a deterministic
# extension ID across machines/reloads. Ask a maintainer for the project's
# key, or generate your own for a fork/different extension identity.
WXT_PUBLIC_KEY=
