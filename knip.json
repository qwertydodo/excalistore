{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "entrypoints/**/*.{ts,tsx,html}",
    "wxt.config.ts",
    "*.config.{ts,js}",
    "src/shared/messages.ts",
    "src/shared/excalidraw-format.ts"
  ],
  "project": ["src/**/*.{ts,tsx}", "entrypoints/**/*.{ts,tsx}"],
  "ignore": [".wxt/**", ".output/**"],
  "ignoreDependencies": ["@wxt-dev/module-react", "@testing-library/react"]
}
