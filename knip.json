{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "entrypoints/**/*.{ts,tsx,html}",
    "wxt.config.ts",
    "*.config.{ts,js}",
    "src/**/index.ts"
  ],
  "project": ["src/**/*.{ts,tsx}", "entrypoints/**/*.{ts,tsx}"],
  "rules": {
    "unresolved": "off"
  },
  "ignoreDependencies": [
    "@wxt-dev/module-react",
    "@babel/core",
    "@types/babel__core",
    "babel-plugin-react-compiler"
  ]
}
